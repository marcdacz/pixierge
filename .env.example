POSTGRES_DB=pixierge
POSTGRES_USER=pixierge
POSTGRES_PASSWORD=pixierge
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/pixierge
SPRING_DATASOURCE_USERNAME=pixierge
SPRING_DATASOURCE_PASSWORD=pixierge

PIXIERGE_BACKGROUND_JOBS_MAX_CONCURRENT_JOBS=3
PIXIERGE_BACKGROUND_JOBS_IDENTITY_BATCH_SIZE=100
PIXIERGE_BACKGROUND_JOBS_CLAIM_BATCH_SIZE=25
PIXIERGE_BACKGROUND_JOBS_POLL_INTERVAL_MS=1000

VITE_API_BASE_URL=http://localhost:8080
VITE_PROXY_TARGET=http://api:8080
